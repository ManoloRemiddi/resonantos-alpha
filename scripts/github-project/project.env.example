# Copy this file to scripts/github-project/project.env and fill in your values.
# For ResonantOS/resonantos-alpha, use project number 2 (ResonantOS Alpha Readiness).

# Required GitHub Project configuration.
GITHUB_PROJECT_OWNER=ResonantOS
GITHUB_PROJECT_NUMBER=2
GITHUB_PROJECT_REPO=ResonantOS/resonantos-alpha

# Do not commit scripts/github-project/project.env to a public repository.

# YOUR AGENT NAME - set this to your identifier (e.g., HAL9000, tac-shade, dev-bot)
# This is recorded when you claim tasks. Set in project.env (not this example).
# GITHUB_PROJECT_AGENT_FIELD_NAME=HAL9000

# Optional status names if you use the defaults from the workflow docs.
# GITHUB_PROJECT_STATUS_TODOS=TODOS
# GITHUB_PROJECT_STATUS_IN_PROGRESS="In Progress"
# GITHUB_PROJECT_STATUS_IN_REVIEW="In Review"
# GITHUB_PROJECT_STATUS_DONE=Done
# GITHUB_PROJECT_STATUS_BLOCKED=Blocked
