[
  {
    "id": "trust-gate",
    "name": "Trust Level Gate",
    "category": "access",
    "description": "Agents have trust levels 1-5. Dangerous tools require trust >= 3.",
    "trigger": "Agent attempts to use a dangerous tool",
    "steps": [
      {"id": "s1", "label": "Tool request", "type": "action", "description": "Agent requests to use a tool"},
      {"id": "s2", "label": "Is dangerous?", "type": "decision", "description": "Check if tool is in dangerous_tool list (exec, file_delete, solana_cli, nft_minter, token_manager)"},
      {"id": "s3", "label": "Trust >= 3?", "type": "decision", "description": "Check agent's trust_level is at least 3"},
      {"id": "s4", "label": "Allow", "type": "action", "description": "Tool use permitted"},
      {"id": "s5", "label": "Block", "type": "gate", "description": "Insufficient trust level — tool use denied"}
    ],
    "edges": [
      {"from": "s1", "to": "s2"},
      {"from": "s2", "to": "s3", "label": "yes"},
      {"from": "s2", "to": "s4", "label": "no (safe tool)"},
      {"from": "s3", "to": "s4", "label": "yes"},
      {"from": "s3", "to": "s5", "label": "no"}
    ]
  },
  {
    "id": "spawn-gate",
    "name": "Spawn Permission Gate",
    "category": "access",
    "description": "Controls which agents can spawn which other agents. Checks can_spawn and blocked_spawn.",
    "trigger": "Agent attempts to spawn another agent",
    "steps": [
      {"id": "s1", "label": "Spawn request", "type": "action", "description": "Agent A requests to spawn Agent B"},
      {"id": "s2", "label": "can_spawn?", "type": "decision", "description": "Check if can_spawn(A, B) exists in rules"},
      {"id": "s3", "label": "blocked_spawn?", "type": "decision", "description": "Check if blocked_spawn(A, B) overrides permission"},
      {"id": "s4", "label": "Allow spawn", "type": "action", "description": "Spawn permitted — spawn_allowed(A, B)"},
      {"id": "s5", "label": "Block spawn", "type": "gate", "description": "No spawn permission or explicitly blocked"}
    ],
    "edges": [
      {"from": "s1", "to": "s2"},
      {"from": "s2", "to": "s3", "label": "yes"},
      {"from": "s2", "to": "s5", "label": "no"},
      {"from": "s3", "to": "s5", "label": "yes (blocked)"},
      {"from": "s3", "to": "s4", "label": "no (not blocked)"}
    ]
  },
  {
    "id": "delegation-gate",
    "name": "Delegation Enforcement",
    "category": "delegation",
    "description": "Enforces that certain agents must delegate specific task types to designated targets.",
    "trigger": "Agent attempts a task type it must delegate",
    "steps": [
      {"id": "s1", "label": "Task attempt", "type": "action", "description": "Agent attempts a task (code, test, design, etc.)"},
      {"id": "s2", "label": "requires_delegation?", "type": "decision", "description": "Check if agent must delegate this task type"},
      {"id": "s3", "label": "Resolve target", "type": "action", "description": "Look up should_delegate(Agent, TaskType, Target)"},
      {"id": "s4", "label": "Delegate to target", "type": "delegation", "description": "Must delegate to the resolved target agent", "agent": "target"},
      {"id": "s5", "label": "Execute directly", "type": "action", "description": "Agent can handle this task type itself"}
    ],
    "edges": [
      {"from": "s1", "to": "s2"},
      {"from": "s2", "to": "s3", "label": "yes"},
      {"from": "s2", "to": "s5", "label": "no"},
      {"from": "s3", "to": "s4"}
    ]
  },
  {
    "id": "sensitive-data-gate",
    "name": "Sensitive Data Gate",
    "category": "security",
    "description": "Detects and blocks emission of sensitive data types (API keys, tokens, private keys, seed phrases, passwords).",
    "trigger": "Output contains potential sensitive data patterns",
    "steps": [
      {"id": "s1", "label": "Output generated", "type": "action", "description": "Agent produces output text"},
      {"id": "s2", "label": "Pattern scan", "type": "action", "description": "Shield scanner checks against sensitive_pattern list (sk-, ghp_, xoxb-, -----BEGIN, etc.)"},
      {"id": "s3", "label": "Match found?", "type": "decision", "description": "Does output match any sensitive_pattern?"},
      {"id": "s4", "label": "Is forbidden?", "type": "decision", "description": "Check if matched type is in forbidden_output_type"},
      {"id": "s5", "label": "Block output", "type": "gate", "description": "Output blocked — contains forbidden sensitive data"},
      {"id": "s6", "label": "Allow output", "type": "action", "description": "Output passes sensitive data check"}
    ],
    "edges": [
      {"from": "s1", "to": "s2"},
      {"from": "s2", "to": "s3"},
      {"from": "s3", "to": "s4", "label": "yes"},
      {"from": "s3", "to": "s6", "label": "no"},
      {"from": "s4", "to": "s5", "label": "yes"},
      {"from": "s4", "to": "s6", "label": "no (warn only)"}
    ]
  },
  {
    "id": "injection-detection",
    "name": "Injection Detection Gate",
    "category": "security",
    "description": "Detects prompt injection patterns in input (ignore previous instructions, DAN mode, jailbreak, etc.).",
    "trigger": "Incoming message or prompt",
    "steps": [
      {"id": "s1", "label": "Input received", "type": "action", "description": "Message arrives from user or external source"},
      {"id": "s2", "label": "Pattern match", "type": "action", "description": "Scan against 13 known injection_pattern strings"},
      {"id": "s3", "label": "Injection found?", "type": "decision", "description": "Does input match any injection pattern?"},
      {"id": "s4", "label": "Flag & block", "type": "gate", "description": "Input flagged as potential injection — blocked or sanitized"},
      {"id": "s5", "label": "Pass through", "type": "action", "description": "Input is clean, proceed normally"}
    ],
    "edges": [
      {"from": "s1", "to": "s2"},
      {"from": "s2", "to": "s3"},
      {"from": "s3", "to": "s4", "label": "yes"},
      {"from": "s3", "to": "s5", "label": "no"}
    ]
  },
  {
    "id": "destructive-pattern-gate",
    "name": "Destructive Command Gate",
    "category": "security",
    "description": "Blocks execution of destructive shell commands (rm -rf, drop table, format, fork bomb, etc.).",
    "trigger": "Agent attempts to execute a shell command",
    "steps": [
      {"id": "s1", "label": "Command request", "type": "action", "description": "Agent requests exec with a command string"},
      {"id": "s2", "label": "Pattern scan", "type": "action", "description": "Scan against 11 destructive_pattern strings"},
      {"id": "s3", "label": "Destructive?", "type": "decision", "description": "Does command match any destructive pattern?"},
      {"id": "s4", "label": "Block execution", "type": "gate", "description": "Command blocked — contains destructive pattern"},
      {"id": "s5", "label": "Allow execution", "type": "action", "description": "Command passes destructive check"}
    ],
    "edges": [
      {"from": "s1", "to": "s2"},
      {"from": "s2", "to": "s3"},
      {"from": "s3", "to": "s4", "label": "yes"},
      {"from": "s3", "to": "s5", "label": "no"}
    ]
  },
  {
    "id": "protected-path-gate",
    "name": "Protected Path Gate",
    "category": "security",
    "description": "Prevents modification of protected files (openclaw.json, SSH keys, Solana keys, auth profiles, private SSoT).",
    "trigger": "Agent attempts to write/modify a file",
    "steps": [
      {"id": "s1", "label": "File write request", "type": "action", "description": "Agent attempts to write to a file path"},
      {"id": "s2", "label": "Protected?", "type": "decision", "description": "Is path in protected_path list? (6 protected paths)"},
      {"id": "s3", "label": "Block write", "type": "gate", "description": "Path is protected — write denied without human approval"},
      {"id": "s4", "label": "In safe_path?", "type": "decision", "description": "Is path under workspace/, resonantos-alpha/, or resonantos-alpha/?"},
      {"id": "s5", "label": "Allow write", "type": "action", "description": "Path is safe and writable — ai_writable(Path)"},
      {"id": "s6", "label": "Unknown path", "type": "gate", "description": "Path not in safe or protected lists — requires review"}
    ],
    "edges": [
      {"from": "s1", "to": "s2"},
      {"from": "s2", "to": "s3", "label": "yes"},
      {"from": "s2", "to": "s4", "label": "no"},
      {"from": "s4", "to": "s5", "label": "yes"},
      {"from": "s4", "to": "s6", "label": "no"}
    ]
  },
  {
    "id": "mainnet-approval-gate",
    "name": "Mainnet Human Approval Gate",
    "category": "blockchain",
    "description": "All mainnet blockchain operations (transfer, mint, deploy, close) require explicit human approval.",
    "trigger": "Agent attempts a blockchain operation on mainnet",
    "steps": [
      {"id": "s1", "label": "Blockchain op", "type": "action", "description": "Agent requests a blockchain operation (transfer, mint, deploy, close)"},
      {"id": "s2", "label": "Which network?", "type": "decision", "description": "Is operation on devnet, testnet, or mainnet?"},
      {"id": "s3", "label": "Allow (testnet)", "type": "action", "description": "Devnet/testnet operations proceed without approval"},
      {"id": "s4", "label": "Human approval", "type": "gate", "description": "Mainnet operation requires explicit human approval before proceeding"},
      {"id": "s5", "label": "Approved?", "type": "decision", "description": "Did the human approve?"},
      {"id": "s6", "label": "Execute", "type": "action", "description": "Human approved — proceed with mainnet operation"},
      {"id": "s7", "label": "Abort", "type": "gate", "description": "Human denied — operation cancelled"}
    ],
    "edges": [
      {"from": "s1", "to": "s2"},
      {"from": "s2", "to": "s3", "label": "devnet/testnet"},
      {"from": "s2", "to": "s4", "label": "mainnet"},
      {"from": "s4", "to": "s5"},
      {"from": "s5", "to": "s6", "label": "yes"},
      {"from": "s5", "to": "s7", "label": "no"}
    ]
  },
  {
    "id": "token-cap-gate",
    "name": "Token Safety Cap Gate",
    "category": "blockchain",
    "description": "Enforces yearly and daily limits on token operations ($RCT: 10K/year, 1/day claim; $RES: 1M/year, 500/day claim).",
    "trigger": "Token mint, transfer, or claim operation",
    "steps": [
      {"id": "s1", "label": "Token operation", "type": "action", "description": "Agent requests token mint/transfer/claim"},
      {"id": "s2", "label": "Daily limit?", "type": "decision", "description": "Check daily_claim_limit (RCT: 1/day, RES: 500/day)"},
      {"id": "s3", "label": "Yearly cap?", "type": "decision", "description": "Check token_yearly_cap (RCT: 10K/year, RES: 1M/year)"},
      {"id": "s4", "label": "Allow operation", "type": "action", "description": "Within both limits — operation permitted"},
      {"id": "s5", "label": "Block (daily)", "type": "gate", "description": "Daily claim limit exceeded"},
      {"id": "s6", "label": "Block (yearly)", "type": "gate", "description": "Yearly token cap exceeded"}
    ],
    "edges": [
      {"from": "s1", "to": "s2"},
      {"from": "s2", "to": "s5", "label": "exceeded"},
      {"from": "s2", "to": "s3", "label": "ok"},
      {"from": "s3", "to": "s6", "label": "exceeded"},
      {"from": "s3", "to": "s4", "label": "ok"}
    ]
  },
  {
    "id": "verification-gate",
    "name": "Verification Gate",
    "category": "verification",
    "description": "Code changes require test evidence (curl, browser, unit, manual, script) before git push. Code-review is flagged as weak.",
    "trigger": "Git push with code changes",
    "steps": [
      {"id": "s1", "label": "Git push", "type": "action", "description": "Agent or human attempts to push code changes"},
      {"id": "s2", "label": "Code changes?", "type": "decision", "description": "Does the push contain code file changes?"},
      {"id": "s3", "label": "Verification entry?", "type": "decision", "description": "Does each changed file have a verification entry in shield/verifications.json?"},
      {"id": "s4", "label": "Strong method?", "type": "decision", "description": "Is verification method strong (curl/browser/unit/script) or weak (code_review/untestable)?"},
      {"id": "s5", "label": "Allow push", "type": "action", "description": "All code changes verified with strong evidence"},
      {"id": "s6", "label": "Block push", "type": "gate", "description": "Missing verification entries — push blocked by pre-push hook"},
      {"id": "s7", "label": "Warn (weak)", "type": "action", "description": "Push allowed but flagged — code_review/untestable is not full verification"}
    ],
    "edges": [
      {"from": "s1", "to": "s2"},
      {"from": "s2", "to": "s5", "label": "no code"},
      {"from": "s2", "to": "s3", "label": "yes"},
      {"from": "s3", "to": "s6", "label": "missing"},
      {"from": "s3", "to": "s4", "label": "present"},
      {"from": "s4", "to": "s5", "label": "strong"},
      {"from": "s4", "to": "s7", "label": "weak"}
    ]
  },
  {
    "id": "coherence-gate",
    "name": "Coherence Gate",
    "category": "verification",
    "description": "Prevents task drift by requiring active tasks for significant tool use and blocking when drift score is too high.",
    "trigger": "Agent attempts to use a significant tool (write, edit, exec, spawn, message, gateway)",
    "steps": [
      {"id": "s1", "label": "Tool request", "type": "action", "description": "Agent requests a significant tool (write, edit, exec, sessions_spawn, message_send, gateway)"},
      {"id": "s2", "label": "Exempt tool?", "type": "decision", "description": "Is tool exempt? (read, web_search, memory_search, tts, browser, etc.)"},
      {"id": "s3", "label": "Active task?", "type": "decision", "description": "Does cg_active_task(/yes) exist?"},
      {"id": "s4", "label": "Block (no task)", "type": "gate", "description": "No active task — significant tools blocked until task is established"},
      {"id": "s5", "label": "Drift score?", "type": "decision", "description": "Check cg_drift_score: 0=ok, 1=warn, 2+=block"},
      {"id": "s6", "label": "Allow", "type": "action", "description": "Active task exists, drift is acceptable"},
      {"id": "s7", "label": "Warn (drift=1)", "type": "action", "description": "Minor drift detected — tool allowed but flagged"},
      {"id": "s8", "label": "Block (drift>=2)", "type": "gate", "description": "Significant drift from task — tool blocked"}
    ],
    "edges": [
      {"from": "s1", "to": "s2"},
      {"from": "s2", "to": "s6", "label": "yes (exempt)"},
      {"from": "s2", "to": "s3", "label": "no"},
      {"from": "s3", "to": "s4", "label": "no"},
      {"from": "s3", "to": "s5", "label": "yes"},
      {"from": "s5", "to": "s6", "label": "score=0"},
      {"from": "s5", "to": "s7", "label": "score=1"},
      {"from": "s5", "to": "s8", "label": "score>=2"}
    ]
  },
  {
    "id": "model-selection-rule",
    "name": "Model Cost Policy",
    "category": "cost",
    "description": "Assigns models to task types based on cost tiers. Opus for complex reasoning, Haiku for routine/background, Sonnet for middle ground.",
    "trigger": "New task or session requires model selection",
    "steps": [
      {"id": "s1", "label": "Task type", "type": "action", "description": "Identify the task type (architecture, compression, heartbeat, routine, etc.)"},
      {"id": "s2", "label": "Check preferred", "type": "decision", "description": "Look up preferred_model(TaskType, Model)"},
      {"id": "s3", "label": "Opus", "type": "action", "description": "Use Opus (expensive) — architecture, planning, complex reasoning, code review"},
      {"id": "s4", "label": "Haiku", "type": "action", "description": "Use Haiku (cheap) — compression, heartbeat, background tasks"},
      {"id": "s5", "label": "Sonnet", "type": "action", "description": "Use Sonnet (moderate) — routine tasks"}
    ],
    "edges": [
      {"from": "s1", "to": "s2"},
      {"from": "s2", "to": "s3", "label": "architecture/planning/reasoning"},
      {"from": "s2", "to": "s4", "label": "compression/heartbeat/background"},
      {"from": "s2", "to": "s5", "label": "routine"}
    ]
  },
  {
    "id": "gateway-lifecycle-gate",
    "name": "Gateway Lifecycle Gate",
    "category": "system",
    "description": "Gateway stop/restart requires a resume plan. Start/restart blocked during maintenance.",
    "trigger": "Agent attempts gateway stop, restart, or start",
    "steps": [
      {"id": "s1", "label": "Gateway action", "type": "action", "description": "Agent requests gateway stop, restart, or start"},
      {"id": "s2", "label": "Maintenance?", "type": "decision", "description": "Is system in maintenance mode? (blocks start/restart)"},
      {"id": "s3", "label": "Block (maintenance)", "type": "gate", "description": "Start/restart blocked during maintenance"},
      {"id": "s4", "label": "Stop/Restart?", "type": "decision", "description": "Is the action stop or restart?"},
      {"id": "s5", "label": "Resume plan?", "type": "decision", "description": "Has agent provided a resume plan (cron job or scheduled restart)?"},
      {"id": "s6", "label": "Block (no plan)", "type": "gate", "description": "Stop/restart blocked — requires_resume_plan not satisfied"},
      {"id": "s7", "label": "Execute action", "type": "action", "description": "Gateway action proceeds with resume plan"}
    ],
    "edges": [
      {"from": "s1", "to": "s2"},
      {"from": "s2", "to": "s3", "label": "yes"},
      {"from": "s2", "to": "s4", "label": "no"},
      {"from": "s4", "to": "s7", "label": "start only"},
      {"from": "s4", "to": "s5", "label": "stop/restart"},
      {"from": "s5", "to": "s7", "label": "yes"},
      {"from": "s5", "to": "s6", "label": "no"}
    ]
  }
]
