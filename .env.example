# Set OPENCLAW_HOME to your user home directory for cross-platform volume mounts
# Linux/macOS:
# OPENCLAW_HOME=/home/youruser
# OPENCLAW_HOME=/Users/youruser
#
# Windows (PowerShell/Command Prompt):
# OPENCLAW_HOME=C:\Users\youruser
#
# After setting, copy this file to .env and edit the path:
#   cp .env.example .env
